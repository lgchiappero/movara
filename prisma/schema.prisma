generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  accounts      Account[]
  sessions      Session[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  paymentId     String?
  paymentMethod String
  address       Json
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  image     String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Lead {
  id        String   @id @default(cuid())
  nombre    String
  apellido  String?
  dni       String?
  telefono  String
  email     String?
  provincia String?
  mensaje   String?
  createdAt DateTime @default(now())

  pedidos ConfiguracionPedido[]

  @@map("leads")
}

model ConfiguracionPedido {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId          String?
  lead            Lead?   @relation(fields: [leadId], references: [id])
  clienteNombre   String
  clienteEmail    String?
  clienteWhatsapp String

  // Especificación del producto
  modelo        String // "10ft" | "20ft" | "40ft"
  zonaClimatica String // "templada" | "frio_intenso" | "calor_extremo" | "humedad_alta"

  // Baño
  banoInodoro String // "estandar" | "inteligente_bidet"
  banoEspejo  String // "comun" | "inteligente_led"
  banoDucha   String // "estandar_esquinero" | "premium"

  // Cocina
  cocinaTipo      String // "vitroceramica" | "espacio_gas"
  cocinaExtractor Boolean @default(false)
  cocinaAlacena   Boolean @default(false)
  cocinaVentana   Boolean @default(false)

  // Aberturas
  aberturaRejas      Boolean @default(false)
  aberturaMosquitero Boolean @default(false)
  aberturaCortinas   Boolean @default(false)

  // Lavarropas, energía, confort
  lavarropas   String // "sin_preinstalacion" | "con_preinstalacion"
  energiaSolar String // "sin" | "preinstalacion" | "kit_incluido"
  calefon      String // "sin" | "electrico"

  // Exterior
  galeria String // "sin" | "balcon_techo" | "galeria_perimetral"

  // Mejoras térmicas
  mejoraParedes100    Boolean @default(false)
  mejoraTripleVidrio  Boolean @default(false)
  mejoraTechoSandwich Boolean @default(false)

  estado String @default("enviado") // "enviado" | "revisado" | "confirmado"

  @@map("configuraciones_pedido")
}
