generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  accounts      Account[]
  sessions      Session[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  paymentId     String?
  paymentMethod String
  address       Json
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  image     String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Lead {
  id        String   @id @default(cuid())
  nombre    String
  apellido  String?
  dni       String?
  telefono  String
  email     String?
  provincia String?
  mensaje   String?
  createdAt DateTime @default(now())

  pedidos ConfiguracionPedido[]

  @@map("leads")
}

model ConfiguracionPedido {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadId          String?
  lead            Lead?   @relation(fields: [leadId], references: [id])
  clienteNombre   String
  clienteEmail    String?
  clienteWhatsapp String?

  // Especificación del producto — null mientras el registro está "pendiente"
  // (creado desde /admin, todavía no completado por el cliente)
  modelo        String? // "10ft" | "20ft" | "40ft"
  zonaClimatica String? // "templada" | "frio_intenso" | "calor_extremo" | "humedad_alta"

  // Baño
  banoInodoro String? // "estandar" | "inteligente_bidet"
  banoEspejo  String? // "comun" | "inteligente_led"
  banoDucha   String? // "estandar_esquinero" | "premium"

  // Cocina
  cocinaTipo      String? // "vitroceramica" | "espacio_gas"
  cocinaExtractor Boolean @default(false)
  cocinaAlacena   Boolean @default(false)
  cocinaVentana   Boolean @default(false)

  // Aberturas
  aberturaRejas      Boolean @default(false)
  aberturaMosquitero Boolean @default(false)
  aberturaCortinas   Boolean @default(false)

  // Lavarropas, energía, confort
  lavarropaIncluye   Boolean @default(false)
  lavarropaUbicacion String? // "bano" | "cocina" | "espacio_externo"
  energiaSolar       String? // "sin" | "preinstalacion" | "kit_incluido"
  calefon            String? // "sin" | "electrico"

  // Exterior
  galeria String? // "sin" | "balcon_techo" | "galeria_perimetral"

  // Mejoras térmicas
  mejoraParedes100    Boolean @default(false)
  mejoraTripleVidrio  Boolean @default(false)
  mejoraTechoSandwich Boolean @default(false)

  // Acabados y diseño — paredes interiores
  paredInteriorColor         String? // "blanco" | "gris_claro" | "beige" | "madera_clara" | "madera_oscura" | "personalizado"
  paredInteriorRevestimiento String? // "pintura_lisa" | "panel_madera" | "panel_pvc" | "otro"

  // Acabados y diseño — paredes exteriores
  paredExteriorColor         String? // "blanco" | "gris" | "beige" | "arena" | "negro_mate" | "personalizado"
  paredExteriorRevestimiento String? // "chapa_prepintada" | "madera_tratada" | "simil_madera" | "otro"

  // Acabados y diseño — baño
  banoRevestimiento   String? // "ceramico_blanco" | "ceramico_gris" | "marmol_sintetico" | "madera_pvc" | "otro"
  banoColorSanitarios String? // "blanco" | "negro" | "cromo"

  // Acabados y diseño — cocina
  cocinaRevestimiento String? // "ceramico_blanco" | "ceramico_gris" | "acero_inoxidable" | "otro"
  cocinaColorMuebles  String? // "blanco" | "gris" | "madera_clara" | "madera_oscura"

  // Puertas y aberturas — puerta principal
  puertaPrincipalTipo     String? // "placa_simple" | "placa_vidrio_lateral" | "doble_hoja" | "corrediza"
  puertaPrincipalMaterial String? // "acero_pintado" | "aluminio" | "pvc"
  puertaPrincipalColor    String? // "blanco" | "negro" | "gris" | "igual_exterior"

  // Puertas y aberturas — puerta interior
  puertaInteriorTipo  String? // "placa" | "corrediza" | "sin_puerta"
  puertaInteriorColor String? // "igual_paredes" | "blanco" | "natural_madera"

  // Puertas y aberturas — ventanas (todas incluyen DVH y mosquitero)
  ventanaTipo String? // "tipo_a" | "tipo_b" | "tipo_c"

  estado String @default("pendiente") // "pendiente" | "enviado" | "revisado" | "confirmado"

  @@map("configuraciones_pedido")
}
